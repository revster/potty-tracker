{
  "name": "potty-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npx ts-node --project server/tsconfig.json server/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "npx ts-node --project server/tsconfig.json server/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  },
  "allowScripts": {
    "better-sqlite3@9.6.0": true
  }
}
